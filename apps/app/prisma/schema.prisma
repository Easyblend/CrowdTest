generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  auth_id    String    @unique
  name       String
  email      String    @unique
  role       Role      @default(DEV)
  avatar_url String?
  bugs       Bug[]
  projects   Project[]
}

model Bug {
  id          String       @id @default(uuid())
  title       String
  description String
  severity    String
  createdAt   DateTime     @default(now())
  projectId   String
  createdBy   String
  resolved    Boolean      @default(false)
  status      BugStatus    @default(OPEN)
  user        User         @relation(fields: [createdBy], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  screenshots Screenshot[]
}

model Screenshot {
  id        String @id @default(uuid())
  url       String
  bugId     String
  public_id String
  bug       Bug    @relation(fields: [bugId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(uuid())
  name        String
  url         String
  slug        String   @unique
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  bugs        Bug[]
  user        User     @relation(fields: [createdBy], references: [id])
  lastActivityAt DateTime @default(now())
}

model Waitlist {
  id                String   @id @default(uuid())
  email             String   @unique
  confirmed         Boolean  @default(false)
  confirmationToken String?
  createdAt         DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  action        String
  entityType    String
  entityId      String
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  actorId       String?
  ownerId       String?
  projectId     String?
  actorSnapshot Json?
  ownerSnapshot Json?

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([ownerId])
  @@index([projectId])
  @@index([action])
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Role {
  DEV
  TESTER
  ADMIN
}
